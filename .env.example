# Krysalis OS environment (PRD section 9 / CLAUDE.md). All server-only;
# this app has no NEXT_PUBLIC_ variables.

# Postgres. The committed docker-compose.yml serves this URL.
# No Docker? `npx prisma dev` runs a local Postgres and prints its URL.
DATABASE_URL="postgresql://krysalis:krysalis@localhost:5432/krysalis"

# Direct (unpooled) connection for migrations — Prisma `directUrl`. On a
# single-host local Postgres this is the same as DATABASE_URL; on a hosted
# provider (e.g. Neon) it is the unpooled endpoint, while DATABASE_URL is the
# pooled one used at serverless runtime.
DATABASE_URL_UNPOOLED="postgresql://krysalis:krysalis@localhost:5432/krysalis"

# Shared secret for HMAC-signed n8n webhooks (PRD 7.12). Mirrors
# krysalis-gate. This is a DEV PLACEHOLDER so `npm run simulate:booking`
# verifies on a fresh clone — replace it before pointing real n8n traffic
# at this app.
N8N_WEBHOOK_SECRET="dev-not-a-secret"

# n8n endpoint notified when a booking card is claimed (PRD 7.12). Empty
# until the n8n side exists; outbound calls are mocked outside production
# while MOCK_WEBHOOKS is unset.
N8N_CLAIM_WEBHOOK=""

# Webhook mock mode, mirroring the gate repo exactly:
# unset = mock everywhere except production · "true" = force mocks ·
# "false" = force real calls. In mock mode, claiming a card whose company
# contains "409" simulates an outbound failure so the admin resend path is
# demoable offline.
# MOCK_WEBHOOKS="true"

# Optional. Enables the model-backed Shadow adapter (M8 stretch); the build
# never requires it.
# ANTHROPIC_API_KEY=""
